<Window x:Class="EvChargerUI.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EvChargerUI" xmlns:commons="clr-namespace:EvChargerUI.ViewModels.Commons" d:DataContext="{d:DesignInstance Type=commons:BaseViewModel}"
        xmlns:views="clr-namespace:EvChargerUI.Views"
        xmlns:converters="clr-namespace:EvChargerUI.Commons.Converters"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Normal"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Width="1024" Height="768"
        MinWidth="768" MinHeight="512"
        MaxWidth="1080" MaxHeight="960">
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenPasswordPopupCommand}" />
    </Window.InputBindings>
    <Window.Resources>
    </Window.Resources>
    <Grid>
        <Grid Background="#222629">
            <Grid.RowDefinitions>
                <RowDefinition Height="432*"/>
                <RowDefinition Height="14*" />
                <RowDefinition Height="46*"/>
                <RowDefinition Height="20*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20*"/>
                    <RowDefinition Height="412*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24*"/>
                        <ColumnDefinition Width="348*"/>
                        <ColumnDefinition Width="24*"/>
                        <ColumnDefinition Width="348*"/>
                        <ColumnDefinition Width="24*"/>
                    </Grid.ColumnDefinitions>
                    <ContentControl Grid.Column="1" Grid.ColumnSpan="{Binding ChargerViewColSpan}" Content="{Binding LeftChargerView}" />
                    <ContentControl Grid.Column="3" Visibility="{Binding RightChargerView, Converter={StaticResource InverseNullToVisibilityConverter}}" Content="{Binding RightChargerView}" />
                </Grid>

            </Grid>
            <Grid Grid.Row="0" Visibility="{Binding ShowInitView, Converter={StaticResource BoolToVisibilityConverter}}" Background="#222629" ZIndex="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24*"/>
                    <RowDefinition Height="408*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24*"/>
                    <ColumnDefinition Width="720*"/>
                    <ColumnDefinition Width="24*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="1" Grid.Column="1">
                    <ContentControl Content="{Binding InitView}"/>
                </Grid>
            </Grid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24*"/>
                    <ColumnDefinition Width="720*"/>
                    <ColumnDefinition Width="24*"/>
                </Grid.ColumnDefinitions>
                <views:BottomView Grid.Column="1"/>
            </Grid>
        </Grid>
        <Grid Visibility="{Binding IsDimmed, Converter={StaticResource BoolToVisibilityConverter}}" Background="#99000000" ZIndex="20">
            <ContentControl Content="{Binding ErrorPopupView}"
                            Visibility="{Binding IsErrorPopupActive, Converter={StaticResource BoolToVisibilityConverter}}"
                            ContentTemplate="{StaticResource SmallPopupTemplate}"
                            Panel.ZIndex="0" />
            <ContentControl Content="{Binding PopupView}" Panel.ZIndex="10">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource SmallPopupTemplate}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PopupType}" Value="Large">
                                <Setter Property="ContentTemplate" Value="{StaticResource LargePopupTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding PopupType}" Value="Alert">
                                <Setter Property="ContentTemplate" Value="{StaticResource AlertPopupTemplate}" />
                            </DataTrigger>

                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>

            <Grid Panel.ZIndex="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="432*"/>
                    <RowDefinition Height="14*"/>
                    <RowDefinition Height="46*"/>
                    <RowDefinition Height="20*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24*"/>
                    <ColumnDefinition Width="720*"/>
                    <ColumnDefinition Width="24*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="2" Grid.Column="1"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0"
                        Background="Transparent" BorderThickness="0"
                        Command="{Binding HiddenBtnDbClickCommand}"
                        Focusable="False" IsTabStop="False"
                        Visibility="{Binding IsAdminIconTapAllowed, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent">
                                <ContentPresenter />
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <Image Source="/Images/logo_evgov.png" Opacity="0"/>
                </Button>
            </Grid>
        </Grid>
        
    </Grid>
</Window>
