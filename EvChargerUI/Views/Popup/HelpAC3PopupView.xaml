<UserControl x:Class="EvChargerUI.Views.Popup.HelpAC3PopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views.Popup" xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="345" d:DesignWidth="360">
    <Grid>
        <Border Grid.Column="0"  Background="#FFFFFF" BorderThickness="0" CornerRadius="12"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="308*"/>
                <ColumnDefinition Width="26*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="174*"/>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="49*"/>
                    <RowDefinition Height="26*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Row="1">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  HelpPopupTitleStyle}" Text="AC 3상이란?"/>
                </Viewbox>
                <Viewbox Grid.Row="3">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  PopupTitleStyle}">
                        AC 3상은 일반 AC 단상보다
                        <LineBreak/>
                        더 높은 전력을 공급해 완속이지만
                        <LineBreak/>
                        더 빠른 충전이 가능한 방식입니다.
                        <LineBreak/>
                        집·직장·건물 등에 설치된 AC 단자를
                        <LineBreak/> 
                        통해 안정적으로 충전할 수 있습니다.
                        <LineBreak/>
                        
                    </controls:LetterSpacingTextBlock>
                </Viewbox>
                <Button Grid.Row="5" Style="{StaticResource ConfirmPopupButtonStyle}"  Command="{Binding CloseCommonPopupCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>


