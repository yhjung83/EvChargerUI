<UserControl x:Class="EvChargerUI.Views.Popup.HelpDCComboPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views.Popup" xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="345" d:DesignWidth="360">
    <Grid>
        <Border Grid.Column="0"  Background="#FFFFFF" BorderThickness="0" CornerRadius="12"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="308*"/>
                <ColumnDefinition Width="26*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="174*"/>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="49*"/>
                    <RowDefinition Height="26*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Row="1">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  HelpPopupTitleStyle}" Text="DC콤보란?"/>
                </Viewbox>
                <Viewbox Grid.Row="3">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  PopupTitleStyle}">
                        DC콤보는 하나의 포트에서 완속(AC)과
                        <LineBreak/>
                        급속(DC) 충전을 모두 지원하는
                        <LineBreak/>
                        통합 충전 방식입니다.
                        <LineBreak/>
                        DC 단자를 연결하면 급속충전,
                        <LineBreak/> 
                        AC 단자를 연결하면
                        <LineBreak/>
                        완속충전이 가능합니다.
                    </controls:LetterSpacingTextBlock>
                </Viewbox>
                <Button Grid.Row="5" Style="{StaticResource ConfirmPopupButtonStyle}"  Command="{Binding CloseCommonPopupCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>


