<UserControl x:Class="EvChargerUI.Views.Popup.HelpDCChademoPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views.Popup" xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="345" d:DesignWidth="360">
    <Grid>
        <Border Grid.Column="0"  Background="#FFFFFF" BorderThickness="0" CornerRadius="12"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="308*"/>
                <ColumnDefinition Width="26*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="174*"/>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="49*"/>
                    <RowDefinition Height="26*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Row="1">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  HelpPopupTitleStyle}" Text="DC차데모란?"/>
                </Viewbox>
                <Viewbox Grid.Row="3">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  PopupTitleStyle}">
                        DC차데모는 일본에서 만든 급속충전
                        <LineBreak/>
                        전용 표준 규격으로,
                        <LineBreak/>
                        큰 원형 단자를 사용합니다.
                        <LineBreak/>
                        차데모 단자를 연결하면 배터리에
                        <LineBreak/> 
                        직접 DC 전력을 공급해
                        <LineBreak/>
                        빠르게 충전할 수 있습니다.
                    </controls:LetterSpacingTextBlock>
                </Viewbox>
                <Button Grid.Row="5" Style="{StaticResource ConfirmPopupButtonStyle}"  Command="{Binding CloseCommonPopupCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>


