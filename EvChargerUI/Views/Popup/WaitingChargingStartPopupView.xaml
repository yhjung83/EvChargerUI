<UserControl x:Class="EvChargerUI.Views.Popup.WaitingChargingStartPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views.Popup" xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="345" d:DesignWidth="360">
    <Grid>
        <Border Grid.Column="0"  Background="#FFFFFF" BorderThickness="0" CornerRadius="12"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="308*"/>
                <ColumnDefinition Width="26*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="24*"/>
                    <RowDefinition Height="100*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="48*"/>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="49*"/>
                    <RowDefinition Height="26*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Row="1">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  PopupTitleStyle}" Text="잠시만 기다려 주세요!"/>
                </Viewbox>
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104*"/>
                        <ColumnDefinition Width="100*"/>
                        <ColumnDefinition Width="104*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="1" x:Name="WaitingImage"/>
                </Grid>
                <Viewbox Grid.Row="5">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  PopupContentStyle}">
                        차량과 커넥터 인식시간에
                        <Run Text="{Binding WaitingChargeDisplaySeconds}" /> 초 남았습니다.
                        <LineBreak/>
                        곧 충전이 시작됩니다.
                    </controls:LetterSpacingTextBlock>

                </Viewbox>
                <Button Grid.Row="7"
                        Command="{Binding CancleWaitForConnectorPlugInCommand}"
                        IsEnabled="{Binding IsCancelWaitForConnectorPlugInEnabled}"
                        Style="{StaticResource CancelPopupButtonStyle}"/>
                
            </Grid>
            
        </Grid>
    </Grid>
</UserControl>
