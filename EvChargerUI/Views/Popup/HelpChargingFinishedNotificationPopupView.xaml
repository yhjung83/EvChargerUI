<UserControl x:Class="EvChargerUI.Views.Popup.HelpChargingFinishedNotificationPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views.Popup" xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="345" d:DesignWidth="360">
    <Grid>
        <Border Grid.Column="0"  Background="#FFFFFF" BorderThickness="0" CornerRadius="12"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="308*"/>
                <ColumnDefinition Width="26*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="154*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="154*"/>
                </Grid.ColumnDefinitions>
    
                <Grid.RowDefinitions>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="174*"/>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="49*"/>
                    <RowDefinition Height="26*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  HelpPopupTitleStyle}" Text="종료알림"/>
                </Viewbox>
                <Viewbox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  PopupTitleStyle}">
                        휴대폰 번호로 종료 알림을 설정하면,
                        <LineBreak/>
                        충전이 완료될 때 해당 번호로
                        <LineBreak/>
                        안내 메시지를 받을 수 있습니다.
                        <LineBreak/>
                        <LineBreak/>
                        <LineBreak/>
                    </controls:LetterSpacingTextBlock>
                </Viewbox>
                <Button Grid.Row="5" Grid.Column="0" Command="{Binding CloseCommonPopupCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Border x:Name="ButtonBorder"
                            Background="#F3F4F6"
                            BorderThickness="1"
                            CornerRadius="6"
                            />
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="14*"/>
                                                    <RowDefinition Height="22*"/>
                                                    <RowDefinition Height="13*"/>
                                                </Grid.RowDefinitions>
                                                <Viewbox Grid.Row="1" HorizontalAlignment="Center">
                                                    <controls:LetterSpacingTextBlock Text="취소하기"
                                             Style="{StaticResource CancelPopupTextStyle}"/>
                                                </Viewbox>
                                            </Grid>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Row="5" Grid.Column="2" Command="{Binding RegisterChargeEndAlarmCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Border x:Name="ButtonBorder" Background="#1BA1C8" BorderThickness="1" CornerRadius="6"/>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="14*"/>
                                                    <RowDefinition Height="22*"/>
                                                    <RowDefinition Height="13*"/>
                                                </Grid.RowDefinitions>
                                                <Viewbox Grid.Row="1" HorizontalAlignment="Center">
                                                    <controls:LetterSpacingTextBlock Text="종료알림 설정하기" Style="{StaticResource ConfirmPopupTextStyle}"/>
                                                </Viewbox>
                                            </Grid>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>


