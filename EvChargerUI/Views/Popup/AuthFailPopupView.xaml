<UserControl x:Class="EvChargerUI.Views.Popup.AuthFailPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views.Popup" xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="345" d:DesignWidth="360">
    <Grid>
        <Border Grid.Column="0"  Background="#FFFFFF" BorderThickness="0" CornerRadius="12"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="308*"/>
                <ColumnDefinition Width="26*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="120*"/>
                    <RowDefinition Height="6*"/>
                    <RowDefinition Height="48*"/>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="49*"/>
                    <RowDefinition Height="26*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Row="1">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  PopupTitleStyle}" Text="인증 실패"/>
                </Viewbox>
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="94*"/>
                        <ColumnDefinition Width="120*"/>
                        <ColumnDefinition Width="94*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="1" Source="/Images/img_fail_auth.png"/>
                </Grid>
                <Viewbox Grid.Row="5">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  PopupContentStyle}">
                        인증이 실패했습니다.
                        <LineBreak/>
                        다른 방식으로 이용해주세요.
                    </controls:LetterSpacingTextBlock>

                </Viewbox>
                <Button Grid.Row="7" Style="{StaticResource ConfirmPopupButtonStyle}"  Command="{Binding CommonClosePopupCommand}"/>
            </Grid>
            
        </Grid>
    </Grid>
</UserControl>
