<UserControl x:Class="EvChargerUI.Views.Popup.HelpChargingCapacityPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views.Popup" xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="345" d:DesignWidth="360">
    <Grid>
        <Border Grid.Column="0"  Background="#FFFFFF" BorderThickness="0" CornerRadius="12"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="308*"/>
                <ColumnDefinition Width="26*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="28*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="174*"/>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="49*"/>
                    <RowDefinition Height="26*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Row="1">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  HelpPopupTitleStyle}" Text="충전용량이란?"/>
                </Viewbox>
                <Viewbox Grid.Row="3">
                    <controls:LetterSpacingTextBlock Style="{StaticResource  PopupTitleStyle}">
                        충전용량(kW)은 충전기가 1시간 동안
                        <LineBreak/>
                        차량에 공급할 수 있는 전력량으로,
                        <LineBreak/>
                        숫자가 클수록 충전 속도가 빠릅니다.
                        <LineBreak/>
                        듀얼 충전기는 표기 용량이 두 포트의
                        <LineBreak/> 
                        합산이며, 예를 들어 100kW는 50kW
                        <LineBreak/>
                        +50kW 구성입니다.
                    </controls:LetterSpacingTextBlock>
                </Viewbox>
                <Button Grid.Row="5" Style="{StaticResource ConfirmPopupButtonStyle}"  Command="{Binding CloseCommonPopupCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>


