<Window x:Class="EvChargerUI.Views.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Debug Output" 
        Width="800" 
        Height="600"
        WindowStartupLocation="Manual"
        Left="100"
        Top="100"
        ResizeMode="CanResize"
        WindowStyle="None"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#F3F4F8" CornerRadius="0" BorderBrush="#CCCCCC" BorderThickness="1">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        
        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#1BA1C8" Padding="10,0" MouseDown="Header_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0"
                          Text="Debug Output Window" 
                          Foreground="White" 
                          FontSize="16" 
                          FontWeight="Bold"
                          VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal" 
                           VerticalAlignment="Center"
                           Margin="10,0">
                    <TextBlock Text="투명도:" 
                              Foreground="White" 
                              FontSize="12"
                              VerticalAlignment="Center"
                              Margin="0,0,5,0"/>
                    <Slider x:Name="OpacitySlider"
                           Minimum="0.3"
                           Maximum="1.0"
                           Value="0.9"
                           Width="100"
                           TickFrequency="0.1"
                           IsSnapToTickEnabled="True"
                           ValueChanged="OpacitySlider_ValueChanged"/>
                    <TextBlock x:Name="OpacityValueText"
                              Text="90%"
                              Foreground="White"
                              FontSize="11"
                              VerticalAlignment="Center"
                              Margin="5,0,0,0"
                              MinWidth="35"
                              TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 로그 출력 영역 -->
        <TextBox Grid.Row="1"
                 x:Name="DebugTextBox" 
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 FontFamily="Consolas"
                 FontSize="11"
                 Background="Black"
                 Foreground="#00FF00"
                 BorderThickness="0"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Margin="5"/>
        
        <!-- 푸터 버튼 -->
        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="1" 
                   Content="Clear" 
                   Click="ClearButton_Click"
                   Background="#E9EBEF"
                   BorderThickness="0"
                   Padding="10,5"
                   Cursor="Hand"/>
            
            <Button Grid.Column="3" 
                   Content="Close" 
                   Click="CloseButton_Click"
                   Background="#1BA1C8"
                   Foreground="White"
                   BorderThickness="0"
                   Padding="10,5"
                   Cursor="Hand"/>
        </Grid>
    </Grid>
    </Border>
</Window>

