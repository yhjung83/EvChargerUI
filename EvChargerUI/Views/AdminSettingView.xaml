<UserControl x:Class="EvChargerUI.Views.AdminSettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views"
             xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             xmlns:converters="clr-namespace:EvChargerUI.Commons.Converters"
             xmlns:media="http://schemas.microsoft.com/expression/media"
             mc:Ignorable="d" 
             Height="440" Width="728">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="AdminButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1BA1C8" CornerRadius="4">
                            <controls:LetterSpacingTextBlock FontFamily="{StaticResource PretendardBoldFont}" FontSize="14" LineHeight="20" Foreground="#FFFFFF" LetterSpacing="-0.2" Text="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Width="170" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AdminSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E9EBEF" CornerRadius="4">
                            <controls:LetterSpacingTextBlock FontFamily="{StaticResource PretendardBoldFont}" FontSize="14" LineHeight="20" Foreground="#97A2B1" LetterSpacing="-0.2" Text="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Width="170" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="#F3F4F8">
        <StackPanel Orientation="Vertical"  >
            <Border Margin="0,0,0,26" Height="376" VerticalAlignment="Top" Background="#FFFFFF" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="298"/>
                        <RowDefinition Height="26"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="328"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="328"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <controls:LetterSpacingTextBlock Grid.Column="1" Grid.Row="1" Text="기본 설정" FontFamily="{StaticResource PretendardBoldFont}" FontSize="16" LineHeight="24" LetterSpacing="-0.2" Foreground="#37404C"/>
                    <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,12,0">
                                <controls:LetterSpacingTextBlock Text="충전소ID" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="충전기ID를 입력해주세요."  Text="{Binding StationId}" />
                            </StackPanel>
                            <StackPanel>
                                <controls:LetterSpacingTextBlock Text="충전소명" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="충전기명을 입력해주세요."  Text="{Binding StationName}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,12,0">
                                <controls:LetterSpacingTextBlock Text="왼쪽 충전기 ID" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="왼쪽 충전기"  Text="{Binding LeftChargerId}" />
                            </StackPanel>
                            <StackPanel>
                                <controls:LetterSpacingTextBlock Text="오른쪽 충전기 ID" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="오른쪽 충전기"  Text="{Binding RightChargerId}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,12,0">
                                <controls:LetterSpacingTextBlock Text="왼쪽 충전기 QR코드" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="왼쪽 충전기 QR코드 입력"  Text="{Binding LeftQrCode}" />
                            </StackPanel>
                            <StackPanel>
                                <controls:LetterSpacingTextBlock Text="오른쪽 충전기 QR코드" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="오른쪽 충전기 QR코드 입력"  Text="{Binding RightQrCode}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,12,0">
                                <controls:LetterSpacingTextBlock Text="충전기 제조사" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkComboBox  Height="28" Width="158" Watermark="충전기 제조사" ItemsSource="{Binding ManufacturerList}" SelectedValue="{Binding SelectedManufacturerId, Mode=TwoWay}"
                                                             SelectedValuePath="Id" DisplayMemberPath="Name"/>
                            </StackPanel>
                            <StackPanel>
                                <controls:LetterSpacingTextBlock Text="결제단말기 제조사" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkComboBox  Height="28" Width="158" Watermark="결제단말기 제조사" ItemsSource="{Binding PaymentManufacturerList}" SelectedValue="{Binding SelectedPaymentManufacturerId, Mode=TwoWay}"
                                                             SelectedValuePath="Id" DisplayMemberPath="Name"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,12,0">
                                <controls:LetterSpacingTextBlock Text="왼쪽 충전기 커넥터 타입" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkComboBox  Height="28" Width="158" Watermark="왼쪽 커넥터 타입" ItemsSource="{Binding ConnectorTypeList}" SelectedValue="{Binding LeftConnectorType, Mode=TwoWay}"
                                                             SelectedValuePath="Id" DisplayMemberPath="Name"/>
                            </StackPanel>
                            <StackPanel>
                                <controls:LetterSpacingTextBlock Text="오른쪽 충전기 커넥터 타입" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkComboBox  Height="28" Width="158" Watermark="오른쪽 커넥터 타입" ItemsSource="{Binding ConnectorTypeList}" SelectedValue="{Binding RightConnectorType, Mode=TwoWay}"
                                                             SelectedValuePath="Id" DisplayMemberPath="Name"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Grid.Row="3">
                        <controls:LetterSpacingTextBlock Text="서버 URL" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                        <controls:WatermarkTextBox Height="28" Width="328" Watermark="서버 URL을 입력해 주세요."  Text="{Binding ServerUrl}" Margin="0,0,0,12"/>
                        <controls:LetterSpacingTextBlock Text="클라이언트 URL" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                        <controls:WatermarkTextBox Height="28" Width="328" Watermark="클라이언트 URL을 입력해 주세요."  Text="{Binding ClientUrl}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,12,0">
                                <controls:LetterSpacingTextBlock Text="DSP COM포트" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="DSP COM포트 입력"  Text="{Binding DspComPort}" />
                            </StackPanel>
                            <StackPanel>
                                <controls:LetterSpacingTextBlock Text="DSP BaudRate" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="DSP BaudRate 입력"  Text="{Binding DspBaudRate}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,12,0">
                                <controls:LetterSpacingTextBlock Text="결제단말기 COM포트" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="결제단말기 COM포트 입력"  Text="{Binding PaymentDeviceComPort}"/>
                            </StackPanel>
                            <StackPanel>
                                <controls:LetterSpacingTextBlock Text="결제단말기 BaudRate" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="결제단말기 BaudRate 입력"  Text="{Binding PaymentDeviceBaudRate}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,12,0">
                                <controls:LetterSpacingTextBlock Text="충전 속도 (kW)" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkTextBox Height="28" Width="158" Watermark="충전 속도 입력 (예: 200)"  Text="{Binding ChargingSpeed}"/>
                            </StackPanel>
                            <!-- 이브이시스일 때 트리플 여부 표시 -->
                            <StackPanel Visibility="{Binding IsEvsisManufacturer, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <controls:LetterSpacingTextBlock Text="트리플 여부" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <CheckBox IsChecked="{Binding IsTriple, Mode=TwoWay}" VerticalAlignment="Center" Height="28" HorizontalAlignment="Left">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="CheckBox">
                                                        <Border Background="#F2F4F6" BorderThickness="0" CornerRadius="14" Width="48" Height="28">
                                                            <Border x:Name="ToggleThumb" Background="#DEE2E7" CornerRadius="14" Width="24" Height="24" Margin="2,2,2,2" HorizontalAlignment="Left"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="ToggleThumb" Property="Background" Value="#1BA1C8"/>
                                                                <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Right"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="False">
                                                                <Setter TargetName="ToggleThumb" Property="Background" Value="#DEE2E7"/>
                                                                <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Left"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                            </StackPanel>
                            <!-- 채비일 때 모델명 표시 -->
                            <StackPanel Visibility="{Binding IsChaeviManufacturer, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <controls:LetterSpacingTextBlock Text="모델명" Style="{StaticResource AdminSettingContentTitleStyle}" Margin="0,0,0,2"/>
                                <controls:WatermarkComboBox Height="28" Width="158" Watermark="모델명 선택" ItemsSource="{Binding ChaeviModelList}" SelectedValue="{Binding SelectedChaeviModelName, Mode=TwoWay}"
                                                             SelectedValuePath="ModelName" DisplayMemberPath="DisplayName"/>
                            </StackPanel>
                        </StackPanel>


                    </StackPanel>
                </Grid>
            </Border>
            <StackPanel Height="39" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource AdminSecondaryButtonStyle}" Margin="0,0, 10, 0" Command="{Binding ChangeToMainViewCommand}" Content="홈으로 이동"/>
                <Button Style="{StaticResource AdminButtonStyle}" Command="{Binding SaveSettingCommand}" Content="저장"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>
