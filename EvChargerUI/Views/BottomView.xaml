<UserControl x:Class="EvChargerUI.Views.BottomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views"
             xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="46" d:DesignWidth="720">
    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="108*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="76*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="76*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="88*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="51*"/>
            <ColumnDefinition Width="12*"/>
            <ColumnDefinition Width="195*"/>
            <ColumnDefinition Width="18*"/>
            <ColumnDefinition Width="80*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0"  Background="#33FFFFFF" BorderThickness="0" CornerRadius="4"/>
        <Grid Grid.Column="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="12*"></ColumnDefinition>
                <ColumnDefinition Width="90*"></ColumnDefinition>
                <ColumnDefinition Width="12*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="7*"></RowDefinition>
                    <RowDefinition Height="14*"></RowDefinition>
                    <RowDefinition Height="18*"></RowDefinition>
                    <RowDefinition Height="7*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="85*"/>
                        <ColumnDefinition Width="15*"/>
                    </Grid.ColumnDefinitions>
                    <Viewbox Grid.Column="0" HorizontalAlignment="Left">
                        <controls:LetterSpacingTextBlock Text="고객센터/고장신고" Style="{StaticResource BottomTitleStyle}" />
                    </Viewbox>
                </Grid>
                <Viewbox Grid.Row="2" HorizontalAlignment="Left">
                    <controls:LetterSpacingTextBlock Text="1661-9408" Style="{StaticResource BottomContentStyle}" />
                </Viewbox>
            </Grid>
        </Grid>
        <Border Grid.Column="2" Background="#33FFFFFF" BorderThickness="0" CornerRadius="4"/>
        <Grid Grid.Column="2" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="12*"></ColumnDefinition>
                <ColumnDefinition Width="46*"></ColumnDefinition>
                <ColumnDefinition Width="30*"></ColumnDefinition>
                <ColumnDefinition Width="12*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="7*"></RowDefinition>
                <RowDefinition Height="14*"></RowDefinition>
                <RowDefinition Height="18*"></RowDefinition>
                <RowDefinition Height="7*"></RowDefinition>
            </Grid.RowDefinitions>
            <Viewbox Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left">
                <controls:LetterSpacingTextBlock Text="충전요금" Style="{StaticResource BottomTitleStyle}" />
            </Viewbox>
            <Viewbox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" HorizontalAlignment="Left">
                <controls:LetterSpacingTextBlock Text="{Binding UnitCostText}" Style="{StaticResource BottomContentStyle}" />
            </Viewbox>
        </Grid>
        <Border Grid.Column="4" Background="#33FFFFFF" BorderThickness="0" CornerRadius="4"/>
        <Button Grid.Column="4"  Background="Transparent" BorderThickness="0" Command="{Binding OpenPopupHelpChargingCapacityCommand}">
            <Button.Template>
                <ControlTemplate TargetType="Button" >
                    <Grid Grid.Column="4" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="12*"></ColumnDefinition>
                            <ColumnDefinition Width="15*"></ColumnDefinition>
                            <ColumnDefinition Width="46*"></ColumnDefinition>
                            <ColumnDefinition Width="22*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="7*"></RowDefinition>
                            <RowDefinition Height="14*"></RowDefinition>
                            <RowDefinition Height="18*"></RowDefinition>
                            <RowDefinition Height="7*"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Viewbox Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left">
                            <Image Grid.Column="1" Source="/Images/ic_help_white.png"/>
                        </Viewbox>
                        <Viewbox Grid.Column="2" Grid.Row="1" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Text="충전용량" Style="{StaticResource BottomTitleStyle}" />
                        </Viewbox>
                        <Viewbox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Text="{Binding ChargingSpeedText}" Style="{StaticResource BottomContentStyle}" />
                        </Viewbox>
                    </Grid>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button Grid.Column="6"  Background="Transparent" BorderThickness="0" Command="{Binding OpenPopupSearchStationQrCodeCommand}">
            <Button.Template>
                <ControlTemplate TargetType="Button" >
                    <Grid>
                        <Border Background="#ECECEC" BorderThickness="0" CornerRadius="4"/>
                        <Grid >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="12*"></ColumnDefinition>
                                <ColumnDefinition Width="64*"></ColumnDefinition>
                                <ColumnDefinition Width="12*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="7*"></RowDefinition>
                                    <RowDefinition Height="14*"></RowDefinition>
                                    <RowDefinition Height="18*"></RowDefinition>
                                    <RowDefinition Height="7*"></RowDefinition>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54*"/>
                                        <ColumnDefinition Width="23"/>
                                    </Grid.ColumnDefinitions>
                                    <Viewbox Grid.Column="0" HorizontalAlignment="Left">
                                        <controls:LetterSpacingTextBlock Text="버튼을 눌러" Style="{StaticResource BottomSubtitleDarkStyle}" />
                                    </Viewbox>
                                </Grid>
                                <Viewbox Grid.Row="2" HorizontalAlignment="Left">
                                    <controls:LetterSpacingTextBlock Text="충전소찾기" Style="{StaticResource BottomContentDarkStyle}" />
                                </Viewbox>
                            </Grid>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Grid Grid.Column="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="32*"></RowDefinition>
                <RowDefinition Height="2*"></RowDefinition>
                <RowDefinition Height="12*"></RowDefinition>
            </Grid.RowDefinitions>
            <Viewbox Grid.Row="0" HorizontalAlignment="Right">
                <controls:LetterSpacingTextBlock Style="{StaticResource BottomStationNameStyle}" >
                    <Run Text="{Binding Path=StationName, Mode=OneWay}"></Run> 
                    <LineBreak/>
                    <Run Text="{Binding Path=StationId, Mode=OneWay}"></Run>
</controls:LetterSpacingTextBlock>
            </Viewbox>
            <Viewbox Grid.Row="2" HorizontalAlignment="Right">
                <controls:LetterSpacingTextBlock Style="{StaticResource BottomVersionStyle}"  >

                    <Run Style="{StaticResource BottomVersionTitleRunStyle}" Text="Ver "/>
                    <Run Style="{StaticResource BottomVersionContentRunStyle}" Text="{Binding ChargerFirmwareVersion, Mode=OneWay}"/>
                    <Run Style="{StaticResource BottomVersionTitleRunStyle}" Text="   App Ver "/>
                    <Run Style="{StaticResource BottomVersionContentRunStyle}" Text="{Binding AppVersion, Mode=OneWay}"/>
                </controls:LetterSpacingTextBlock>
            </Viewbox>
        </Grid>
        <Image Grid.Column="12" Source="/Images/logo_evgov.png">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseLeftButtonDown">
                    <i:InvokeCommandAction Command="{Binding HiddenBtnDbClickCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </Image>
    </Grid>
</UserControl>
