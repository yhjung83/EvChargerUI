<UserControl x:Class="EvChargerUI.Views.DualChannel.ChargingReceiptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views"
             xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
                         d:DesignHeight="360" d:DesignWidth="348">
    <Grid >
        <Border Background="#FFFFFF"  CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26*"/>
                    <ColumnDefinition Width="148*"/>
                    <ColumnDefinition Width="148*"/>
                    <ColumnDefinition Width="26*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="31*"/>
                    <RowDefinition Height="12*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="16*"/>
                    <RowDefinition Height="21*"/>
                    <RowDefinition Height="12*"/>
                    <RowDefinition Height="6*"/>
                    <RowDefinition Height="50*"/>
                    <RowDefinition Height="26*"/>
                </Grid.RowDefinitions>
                    <Viewbox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargerViewHighlightTitleStyle}" Text="충전이 완료되었습니다."/>
                    </Viewbox>

                    <Viewbox Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="충전량"/>
                    </Viewbox>
                    <Viewbox Grid.Row="3" Grid.Column="2" HorizontalAlignment="Right">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteContentStyle}" Text="{Binding PowerMeter, StringFormat={}{0:N2}kWh}"/>
                    </Viewbox>
                    <Viewbox Grid.Row="5" Grid.Column="1" HorizontalAlignment="Left">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="충전금액"/>
                    </Viewbox>
                    <Viewbox Grid.Row="5" Grid.Column="2" HorizontalAlignment="Right">
                    <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteContentStyle}" Text="{Binding FinalChargeAmount, StringFormat={}{0:N0}원}"/>
                    </Viewbox>
                    <Viewbox Grid.Row="7" Grid.Column="1" HorizontalAlignment="Left">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="충전시간"/>
                    </Viewbox>
                    <Viewbox Grid.Row="7" Grid.Column="2" HorizontalAlignment="Right">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteContentStyle}" Text="{Binding ChargeTimeFormatted}"/>
                    </Viewbox>
                <Viewbox Grid.Row="9" Grid.Column="1" HorizontalAlignment="Left">
                    <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="충전 후 배터리"/>
                </Viewbox>
                <Viewbox Grid.Row="9" Grid.Column="2" HorizontalAlignment="Right">
                    <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteBoldContentStyle}" Text="{Binding BatteryAfterCharging}"/>
                </Viewbox>
                <Line Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"></Line>
                <Viewbox Grid.Row="11" Grid.Column="1" HorizontalAlignment="Left">
                    <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="충전 보증금"/>
                </Viewbox>
                <Viewbox Grid.Row="11" Grid.Column="2" HorizontalAlignment="Right">
                    <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteContentStyle}" Text="{Binding DepositAmount, StringFormat={}{0:N0}원}"/>
                </Viewbox>
                <Viewbox Grid.Row="13" Grid.Column="1" HorizontalAlignment="Left">
                    <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="보증금 취소"/>
                </Viewbox>
                <Viewbox Grid.Row="13" Grid.Column="2" HorizontalAlignment="Right">
                    <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteContentStyle}" Text="{Binding CancelCost, StringFormat={}{0:N0}원}"/>
                </Viewbox>
                <Line Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"></Line>
                <Viewbox Grid.Row="15" Grid.Column="1" HorizontalAlignment="Left">
                    <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="최종 결제 금액"/>
                </Viewbox>
                <Viewbox Grid.Row="15" Grid.Column="2" HorizontalAlignment="Right">
                    <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteBoldContentStyle}" Text="{Binding FinalChargeAmount, StringFormat={}{0:N0}원}"/>
                </Viewbox>

                <Grid Grid.Row="17" Grid.Column="1" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="12*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="180*"/>
                        <ColumnDefinition Width="100*"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="/Images/ic_information.png"/>
                    <controls:LetterSpacingTextBlock Grid.Column="2" Style="{StaticResource ChargingCompleteSmallContentStyle}" Text="카드사 영업일 7일 이내 부분 취소 금액 환불" />
                </Grid>
                <Button Grid.Row="19" Grid.Column="1" Grid.ColumnSpan="2" Command="{Binding BackToChargingCompleteCommand}"  Style="{StaticResource CommonConfirmButtonStyle}"/>
            </Grid>

        </Border>
    </Grid>
</UserControl>
