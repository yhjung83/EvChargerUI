<UserControl x:Class="EvChargerUI.Views.DualChannel.ChargingCompleteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views"
             xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="360" d:DesignWidth="348">
    <Grid >
        <Border Background="#FFFFFF"  CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26*"/>
                    <ColumnDefinition Width="296*"/>
                    <ColumnDefinition Width="26*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26*"/>
                        <RowDefinition Height="31*"/>
                        <RowDefinition Height="6*"/>
                        <RowDefinition Height="22*"/>
                        <RowDefinition Height="6*"/>
                        <RowDefinition Height="90*"/>
                        <RowDefinition Height="14*"/>
                        <RowDefinition Height="81*"/>
                        <RowDefinition Height="8*"/>
                        <RowDefinition Height="50*"/>
                        <RowDefinition Height="26*"/>
                    </Grid.RowDefinitions>
                    <Viewbox Grid.Row="1">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargerViewHighlightTitleStyle}" Text="충전이 완료되었습니다."/>
                    </Viewbox>
                    <Viewbox Grid.Row="3">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargerViewSubtitleStyle}" Text="커넥터를 사용 후 제자리에 꼭 꽂아주세요."/>
                    </Viewbox>
                    <Image Grid.Row="5" Source="/Images/img_plug_connector.png"/>
                    <Grid Grid.Row="7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="69*"/>
                            <ColumnDefinition Width="69*"/>
                            <ColumnDefinition Width="20*"/>
                            <ColumnDefinition Width="69*"/>
                            <ColumnDefinition Width="69*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="17*"/>
                            <RowDefinition Height="18*"/>
                            <RowDefinition Height="17*"/>
                            <RowDefinition Height="18*"/>
                        </Grid.RowDefinitions>
                        <Viewbox Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="충전시간"/>
                        </Viewbox>
                        <Viewbox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteContentStyle}" Text="{Binding ChargeTime}"/>
                        </Viewbox>
                        <Viewbox Grid.Row="2" Grid.Column="0" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="충전량"/>
                        </Viewbox>
                        <Viewbox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteContentStyle}" Text="{Binding PowerMeter, StringFormat={}{0:N2}kWh}"/>
                        </Viewbox>
                        <Viewbox Grid.Row="0" Grid.Column="3" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="충전금액"/>
                        </Viewbox>
                        <Viewbox Grid.Row="0" Grid.Column="4" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteContentStyle}" Text="{Binding FinalChargeAmount, StringFormat={}{0:N0}원}"/>
                        </Viewbox>
                        <Viewbox Grid.Row="2" Grid.Column="3" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteSubjectStyle}" Text="설정금액"/>
                        </Viewbox>
                        <Viewbox Grid.Row="2" Grid.Column="4" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource ChargingCompleteContentStyle}" Text="{Binding UserSetCost, StringFormat={}{0:N0}원}"/>
                        </Viewbox>
                        <Line Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"></Line>
                        <Line Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"></Line>
                        <Line Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"></Line>
                        <Line Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"></Line>

                    </Grid>
                    <Grid Grid.Row="9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="142*"/>
                            <ColumnDefinition Width="12*"/>
                            <ColumnDefinition Width="142*"/>
                        </Grid.ColumnDefinitions>
                        <Button  Grid.Column="0"  Command="{Binding ReceiptViewCommand}"   Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button" >
                                    <Grid>
                                        <Border Background="#FFFFFF" BorderThickness="1" CornerRadius="6" BorderBrush="#1BA1C8" />
                                        <Grid >
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="13*"></RowDefinition>
                                                <RowDefinition Height="25*"></RowDefinition>
                                                <RowDefinition Height="12*"></RowDefinition>
                                            </Grid.RowDefinitions>

                                            <Viewbox Grid.Row="1" HorizontalAlignment="Center">
                                                <controls:LetterSpacingTextBlock Text="영수증보기" Style="{StaticResource ButtonTextStyle}" />
                                            </Viewbox>
                                        </Grid>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button  Grid.Column="2"  Command="{Binding InitializeChargerCommand}"   Style="{StaticResource CommonConfirmButtonStyle}"/>
                        
                    </Grid>
                </Grid>
            </Grid>
    
        </Border>
    </Grid>
</UserControl>
