<UserControl x:Class="EvChargerUI.Views.SingleChannel.TripleChargerSelectTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views"
             xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="360" d:DesignWidth="720">
    <Grid>
        <Button Background="Transparent" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="#FFFFFF" CornerRadius="6">
                        <Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26*"></ColumnDefinition>
                                    <ColumnDefinition Width="668*"></ColumnDefinition>
                                    <ColumnDefinition Width="26*"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="26*"></RowDefinition>
                                    <RowDefinition Height="223*"></RowDefinition>
                                    <RowDefinition Height="5*"></RowDefinition>
                                    <RowDefinition Height="48*"></RowDefinition>
                                </Grid.RowDefinitions>

                                <!-- 3개 패널 컨테이너 -->
                                <Grid Grid.Row="1" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100*"/>
                                        <ColumnDefinition Width="10*"/>
                                        <ColumnDefinition Width="100*"/>
                                        <ColumnDefinition Width="10*"/>
                                        <ColumnDefinition Width="100*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- AC3상 패널 -->
                                    <Button Grid.Column="0" Command="{Binding SelectConnectorTypeCommand}" CommandParameter="0" Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#F4FAFC" CornerRadius="15" BorderThickness="2" 
                                                        BorderBrush="Transparent">
                                                    <Grid Margin="20">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="20*"/>
                                                            <RowDefinition Height="5*"/>
                                                            <RowDefinition Height="5"/>
                                                            <RowDefinition Height="5*"/>
                                                            <RowDefinition Height="8*"/>
                                                            <RowDefinition Height="1*"/>
                                                            <RowDefinition Height="10*"/>
                                                            <RowDefinition Height="20*"/>
                                                        </Grid.RowDefinitions>

                                                        <Button Grid.Row="1" Background="Transparent" BorderThickness="0" Command="{Binding OpenConnectorHelpCommand}" CommandParameter="0">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button" >
                                                                    <Image Source="/Images/ic_help_gray.png"/>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <Viewbox Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <controls:LetterSpacingTextBlock Text="커넥터를 선택해주세요." 
                                                                                             Style="{StaticResource ChargerTypeStyle}"/>
                                                        </Viewbox>
                                                        
                                                        <Viewbox Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <controls:LetterSpacingTextBlock Text="AC3상" 
                                                                                             Style="{StaticResource ChargerViewTitleStyle}"/>
                                                        </Viewbox>
                                                        
                                                        <Image Grid.Row="6" Source="/Images/ic_type_charger_ac3.png" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- DC차데모 패널 -->
                                    <Button Grid.Column="2" Command="{Binding SelectConnectorTypeCommand}" CommandParameter="2" Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#F4FAFC" CornerRadius="15" BorderThickness="2" 
                                                        BorderBrush="Transparent">
                                                    <Grid Margin="20">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="20*"/>
                                                            <RowDefinition Height="5*"/>
                                                            <RowDefinition Height="5"/>
                                                            <RowDefinition Height="5*"/>
                                                            <RowDefinition Height="8*"/>
                                                            <RowDefinition Height="1*"/>
                                                            <RowDefinition Height="10*"/>
                                                            <RowDefinition Height="20*"/>
                                                        </Grid.RowDefinitions>

                                                        <Button Grid.Row="1" Background="Transparent" BorderThickness="0" Command="{Binding OpenConnectorHelpCommand}" CommandParameter="2">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button" >
                                                                    <Image Source="/Images/ic_help_gray.png"/>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <Viewbox Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <controls:LetterSpacingTextBlock Text="커넥터를 선택해주세요." 
                                                                                             Style="{StaticResource ChargerTypeStyle}"/>
                                                        </Viewbox>
                                                        
                                                        <Viewbox Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <controls:LetterSpacingTextBlock Text="DC차데모" 
                                                                                             Style="{StaticResource ChargerViewTitleStyle}"/>
                                                        </Viewbox>
                                                        
                                                        <Image Grid.Row="6" Source="/Images/ic_type_charger_chademo.png" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    
                                    <!-- DC콤보 패널 -->
                                    <Button Grid.Column="4" Command="{Binding SelectConnectorTypeCommand}" CommandParameter="1" Background="Transparent" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#F4FAFC" CornerRadius="15" BorderThickness="2" 
                                                        BorderBrush="Transparent">
                                                    <Grid Margin="20">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="20*"/>
                                                            <RowDefinition Height="5*"/>
                                                            <RowDefinition Height="5"/>
                                                            <RowDefinition Height="5*"/>
                                                            <RowDefinition Height="8*"/>
                                                            <RowDefinition Height="1*"/>
                                                            <RowDefinition Height="10*"/>
                                                            <RowDefinition Height="20*"/>
                                                        </Grid.RowDefinitions>

                                                        <Button Grid.Row="1" Background="Transparent" BorderThickness="0" Command="{Binding OpenConnectorHelpCommand}" CommandParameter="1">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button" >
                                                                    <Image Source="/Images/ic_help_gray.png"/>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>

                                                        <Viewbox Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <controls:LetterSpacingTextBlock Text="커넥터를 선택해주세요." 
                                                                                             Style="{StaticResource ChargerTypeStyle}"/>
                                                        </Viewbox>
                                                        
                                                        <Viewbox Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <controls:LetterSpacingTextBlock Text="DC콤보" 
                                                                                             Style="{StaticResource ChargerViewTitleStyle}"/>
                                                        </Viewbox>
                                                        
                                                        <Image Grid.Row="6" Source="/Images/ic_type_charger_dc.png" 
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Grid>
                            
                            <!-- 하단 버튼 영역 -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="301*"></RowDefinition>
                                    <RowDefinition Height="33*"></RowDefinition>
                                    <RowDefinition Height="26*"></RowDefinition>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26*"></ColumnDefinition>
                                    <ColumnDefinition Width="71*"></ColumnDefinition>
                                    <ColumnDefinition Width="623*"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <Image Source="/Images/btn_usable.png" Height="45" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Image x:Name="Test1" Source="/Images/btn_test.png" Height="45" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="{Binding TestVisibility}"/>
                                    <Image x:Name="PayYN1" Source="/Images/btn_payYN.png" Height="45" VerticalAlignment="Center" Visibility="{Binding PayYNVisibility}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
