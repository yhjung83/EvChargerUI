<UserControl x:Class="EvChargerUI.Views.SingleChannel.CalcChargeAmountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views"
             xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="360" d:DesignWidth="720">
    <Grid >
        <Border Background="#FFFFFF"  CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26*"/>
                    <ColumnDefinition Width="324*"/>
                    <ColumnDefinition Width="20*"/>
                    <ColumnDefinition Width="324*"/>
                    <ColumnDefinition Width="26*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="31*"/>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="29*"/>
                    <RowDefinition Height="5*"/>
                    <RowDefinition Height="31*"/>
                    <RowDefinition Height="98*"/>
                    <RowDefinition Height="57*"/>
                    <RowDefinition Height="50*"/>
                    <RowDefinition Height="24*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left" Grid.ColumnSpan="3">
                    <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargerViewHighlightTitleStyle}" Text="사전 결제 금액 취소 및 금액 정산이 완료되었습니다."/>
                </Viewbox>
                <Viewbox Grid.Column="1" Grid.Row="3" HorizontalAlignment="Left" Grid.RowSpan="2">
                    <controls:LetterSpacingTextBlock Style="{StaticResource CalcChargeAmountSubtitleStyle}">
                        정산 요청 후 카드사 영업일 기준 1~14일 후 최종 취소 처리됩니다.
                        <LineBreak/>
                        부분취소의 경우 카드사에서 취소 안내 문자를 발송하지 않습니다.
                    </controls:LetterSpacingTextBlock>
                </Viewbox>

                <Image Grid.Column="1" Grid.Row="6"  Source="/Images/img_battery.png" Grid.ColumnSpan="2" />
                <Border Grid.Column="3" Grid.Row="4" Grid.RowSpan="3" CornerRadius="8" Background="#33D9D9D9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20*"/>
                            <ColumnDefinition Width="142*"/>
                            <ColumnDefinition Width="142*"/>
                            <ColumnDefinition Width="20*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20*"/>
                            <RowDefinition Height="18*"/>
                            <RowDefinition Height="20*"/>
                            <RowDefinition Height="18*"/>
                            <RowDefinition Height="20*"/>
                            <RowDefinition Height="18*"/>
                            <RowDefinition Height="20*"/>
                        </Grid.RowDefinitions>
                        <Viewbox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteSubjectStyle}" Text="사전 결제 금액"/>
                        </Viewbox>
                        <Viewbox Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteContentStyle}" Text="{Binding UserSetCost, StringFormat={}{0:N0}원}"/>
                        </Viewbox>
                        <Viewbox Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteSubjectStyle}" Text="충전 금액"/>
                        </Viewbox>
                        <Viewbox Grid.Row="3" Grid.Column="2" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteContentStyle}" Text="{Binding ChargingCost, StringFormat={}{0:N0}원}"/>
                        </Viewbox>
                        <Viewbox Grid.Row="5" Grid.Column="1" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteSubjectStyle}" Text="취소 요청 금액"/>
                        </Viewbox>
                        <Viewbox Grid.Row="5" Grid.Column="2" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteContentStyle}" Text="{Binding CancelCost, StringFormat={}{0:N0}원}"/>
                        </Viewbox>
                        <Line Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="284" Y2="0" Stretch="Fill"></Line>
                        <Line Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="284" Y2="0" Stretch="Fill"></Line>
                    </Grid>
                </Border>
                <Button Grid.Row="8"  Grid.Column="1"  Command="{Binding ConfrimCalcChargeAmountCommand}" Grid.ColumnSpan="3" Style="{StaticResource CommonConfirmButtonStyle}"/>
            </Grid>

        </Border>
    </Grid>
</UserControl>
