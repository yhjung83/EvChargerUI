<UserControl x:Class="EvChargerUI.Views.SingleChannel.ChargingProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views"
             xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="360" d:DesignWidth="720">
    <Grid>
        <Border CornerRadius="6">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#C9D9CB" Offset="0.0"/>
                    <GradientStop Color="#A0CBA4" Offset="0.4"/>
                    <GradientStop Color="#75BFD8" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="31*"/>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="10*"/>
                    <RowDefinition Height="214*"/>
                    <RowDefinition Height="50*"/>
                    <RowDefinition Height="26*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26*"/>
                    <ColumnDefinition Width="343*"/>
                    <ColumnDefinition Width="36*"/>
                    <ColumnDefinition Width="289*"/>
                    <ColumnDefinition Width="26*"/>
                </Grid.ColumnDefinitions>
                <Viewbox Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left">
                    <controls:LetterSpacingTextBlock  Text="차량이 충전중입니다." Style="{StaticResource SingleChargerViewTitleWhiteStyle}"/>
                </Viewbox>
                <Grid Grid.Row="1" Grid.Column="3" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="121*"/>
                        <ColumnDefinition Width="100*"/>
                        <ColumnDefinition Width="8*"/>
                        <ColumnDefinition Width="75*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1"  Command="{Binding OpenRegisterChargeEndAlarmHelpPopupCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ImageButtonStyle}">
                                <Setter Property="IsEnabled" Value="True"/>
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <Image Source="/Images/btn_reserve_complete_alarm.png"/>
                                    </Setter.Value>
                                </Setter>

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ChargeEndCallbackPhoneNumber}" Value="">
                                        <Setter Property="IsEnabled" Value="True"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding ChargeEndCallbackPhoneNumber}" Value="{x:Null}">
                                        <Setter Property="IsEnabled" Value="True"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding ChargeEndCallbackPhoneNumber, Converter={StaticResource StringNotEmptyConverter}}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <Image Source="/Images/btn_reserve_complete_alarm_disabled.png"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="3" Style="{StaticResource ImageButtonStyle}" Command="{Binding ReserveChargerCommand}" HorizontalAlignment="Right">
                        <Grid>
                            <Image Source="/Images/btn_reserve.png"/>
                            <Border Visibility="{Binding HasReservation, Converter={StaticResource BoolToVisibilityConverter}}" 
                                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                                    Background="#FF4444" CornerRadius="10" 
                                    Width="20" Height="20" 
                                    Margin="0,-5,-5,0">
                                <TextBlock Text="{Binding ReservationCountText}" 
                                          Foreground="White" 
                                          FontSize="12" 
                                          FontWeight="Bold"
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>
                </Grid>
                <Grid Grid.Column="1" Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="175*"/>
                        <RowDefinition Height="12*"/>
                        <RowDefinition Height="15*"/>
                        <RowDefinition Height="12*"/>
                    </Grid.RowDefinitions>
                    <Viewbox Grid.Row="0">
                        <Grid Width="132" Height="132">
                            <Ellipse Width="132" Height="132" Fill="#99F0F0F0"/>
                            <Grid>
                                <Grid.Clip>
                                    <EllipseGeometry Center="66,66" RadiusX="66" RadiusY="66"/>
                                </Grid.Clip>
                                <Rectangle x:Name="ProgressFill"
                                           Width="132"
                                           VerticalAlignment="Bottom"
                                           Fill="#FFFFFF">
                                    <Rectangle.Height>
                                        <MultiBinding Converter="{StaticResource ProgressToHeightConverter}">
                                            <Binding Path="Progress" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualHeight"/>
                                        </MultiBinding>
                                    </Rectangle.Height>
                                </Rectangle>
                            </Grid>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28*"/>
                                    <RowDefinition Height="43*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="14*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="14*"/>
                                    <RowDefinition Height="29*"/>
                                </Grid.RowDefinitions>
                                <controls:LetterSpacingTextBlock Grid.Row="1" Text="{Binding Progress, StringFormat={}{0}%}" Style="{StaticResource ChargingProgressNumberStyle}"/>
                                <controls:LetterSpacingTextBlock Grid.Row="3" Text="충전중입니다." Style="{StaticResource ChargingProgressTextStyle}"/>
                                <Button Grid.Row="5" Command="{Binding OpenChargingSpeedHelpCommand}" Background="Transparent" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button" >
                                            <TextBlock TextAlignment="Center" VerticalAlignment="Center"
                                                       FontFamily="{StaticResource PretendardBoldFont}" FontSize="12" LineHeight="14"
                                                       Foreground="#171616" TextDecorations="Underline" FontWeight="SemiBold">
                                                <Run Text="{Binding Speed, StringFormat={}{0:F1}}" />
                                                <Run Text="kW" />
                                            </TextBlock>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>
                    </Viewbox>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="12*"/>
                            <ColumnDefinition Width="15*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="318*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="1" Source="/Images/ic_alert.png"/>
                        <Grid Grid.Column="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*"/>
                                <RowDefinition Height="13*"/>
                                <RowDefinition Height="1*"/>
                            </Grid.RowDefinitions>
                            <Viewbox Grid.Row="1" HorizontalAlignment="Left">
                                <controls:LetterSpacingTextBlock Text="{Binding ChargeLimitTime, StringFormat='최대 {0}분까지만 충전 가능'}" Style="{StaticResource ChargingProgressAlertStyle}"></controls:LetterSpacingTextBlock>
                            </Viewbox>
                        </Grid>
                    </Grid>
                </Grid>
                <Grid Grid.Column="3" Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44*"/>
                        <RowDefinition Height="18*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="18*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="18*"/>
                        <RowDefinition Height="20*"/>
                        <RowDefinition Height="18*"/>
                        <RowDefinition Height="38*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100*"/>
                        <ColumnDefinition Width="189*"/>
                    </Grid.ColumnDefinitions>
                    <Viewbox Grid.Row="1" Grid.Column="0" HorizontalAlignment="Left">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingProgressSubjectStyle}" Text="충전시간"/>
                    </Viewbox>
                    <Viewbox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingProgressContentStyle}" Text="{Binding ChargeTime}"/>
                    </Viewbox>
                    <Viewbox Grid.Row="3" Grid.Column="0" HorizontalAlignment="Left">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingProgressSubjectStyle}" Text="충전량"/>
                    </Viewbox>
                    <Viewbox Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingProgressContentStyle}" Text="{Binding PowerMeter, StringFormat={}{0:N2}kWh}"/>
                    </Viewbox>
                    <Viewbox Grid.Row="5" Grid.Column="0" HorizontalAlignment="Left">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingProgressSubjectStyle}" Text="충전금액"/>
                    </Viewbox>
                    <Viewbox Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingProgressContentStyle}" Text="{Binding ChargingCost, StringFormat={}{0:N0}원}"/>
                    </Viewbox>
                    <Viewbox Grid.Row="7" Grid.Column="0" HorizontalAlignment="Left">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingProgressSubjectStyle}" Text="설정금액"/>
                    </Viewbox>
                    <Viewbox Grid.Row="7" Grid.Column="1" HorizontalAlignment="Right">
                        <controls:LetterSpacingTextBlock Style="{StaticResource ChargingProgressContentStyle}" Text="{Binding UserSetCost, StringFormat={}{0:N0}원}"/>
                    </Viewbox>
                    <Line Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#4CFFFFFF" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"></Line>
                    <Line Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#4CFFFFFF" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"></Line>
                    <Line Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#4CFFFFFF" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"></Line>
                </Grid>

                <Button  Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3"  Command="{Binding CompleteChargingCommand}"   Background="Transparent" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button" >
                            <Grid>
                                <Border Background="#FFFFFF" BorderThickness="0" CornerRadius="6" />
                                <Grid >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110*"></ColumnDefinition>
                                        <ColumnDefinition Width="76*"></ColumnDefinition>
                                        <ColumnDefinition Width="110*"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="13*"></RowDefinition>
                                        <RowDefinition Height="25*"></RowDefinition>
                                        <RowDefinition Height="12*"></RowDefinition>
                                    </Grid.RowDefinitions>

                                    <Viewbox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center">
                                        <controls:LetterSpacingTextBlock Text="충전완료" Style="{StaticResource ButtonTextStyle}" />
                                    </Viewbox>

                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
