<UserControl x:Class="EvChargerUI.Views.SingleChannel.ChargingCompleteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EvChargerUI.Views"
             xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="360" d:DesignWidth="720">
    <Grid >
        <Border Background="#FFFFFF"  CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26*"/>
                    <ColumnDefinition Width="324*"/>
                    <ColumnDefinition Width="20*"/>
                    <ColumnDefinition Width="324*"/>
                    <ColumnDefinition Width="26*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26*"/>
                    <RowDefinition Height="31*"/>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="17*"/>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="172*"/>
                    <RowDefinition Height="12*"/>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="50*"/>
                    <RowDefinition Height="24*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left">
                    <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargerViewHighlightTitleStyle}" Text="충전이 완료되었습니다."/>
                </Viewbox>
                <Viewbox Grid.Column="1" Grid.Row="3" HorizontalAlignment="Left">
                    <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteSubtitleStyle}" Text="이용해 주셔서 감사합니다. 커넥터를 사용 후 제자리에 꼭 꽂아주세요."/>
                </Viewbox>
                <Image Grid.Column="1" Grid.Row="5" Grid.RowSpan="3" Source="/Images/img_plug_connector.png"/>
                <Border Grid.Column="3" Grid.Row="6" CornerRadius="8" Background="#33D9D9D9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20*"/>
                            <ColumnDefinition Width="142*"/>
                            <ColumnDefinition Width="142*"/>
                            <ColumnDefinition Width="20*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20*"/>
                            <RowDefinition Height="18*"/>
                            <RowDefinition Height="20*"/>
                            <RowDefinition Height="18*"/>
                            <RowDefinition Height="20*"/>
                            <RowDefinition Height="18*"/>
                            <RowDefinition Height="20*"/>
                            <RowDefinition Height="18*"/>
                            <RowDefinition Height="20*"/>
                        </Grid.RowDefinitions>

                        <Viewbox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteSubjectStyle}" Text="충전시간"/>
                        </Viewbox>
                        <Viewbox Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteContentStyle}" Text="{Binding ChargeTime}"/>
                        </Viewbox>

                        <Viewbox Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteSubjectStyle}" Text="충전량"/>
                        </Viewbox>
                        <Viewbox Grid.Row="3" Grid.Column="2" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteContentStyle}" Text="{Binding PowerMeter, StringFormat={}{0:N2}kWh}"/>
                        </Viewbox>
                        <Viewbox Grid.Row="5" Grid.Column="1" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteSubjectStyle}" Text="충전금액"/>
                        </Viewbox>
                        <Viewbox Grid.Row="5" Grid.Column="2" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteContentStyle}" Text="{Binding FinalChargeAmount, StringFormat={}{0:N0}원}"/>
                        </Viewbox>
                        <Viewbox Grid.Row="7" Grid.Column="1" HorizontalAlignment="Left">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteSubjectStyle}" Text="설정금액"/>
                        </Viewbox>
                        <Viewbox Grid.Row="7" Grid.Column="2" HorizontalAlignment="Right">
                            <controls:LetterSpacingTextBlock Style="{StaticResource SingleChargingCompleteContentStyle}" Text="{Binding UserSetCost, StringFormat={}{0:N0}원}"/>
                        </Viewbox>
                        <Line Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="284" Y2="0" Stretch="Fill"></Line>
                        <Line Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="284" Y2="0" Stretch="Fill"></Line>
                        <Line Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="284" Y2="0" Stretch="Fill"></Line>


                    </Grid>
                </Border>
                <Button Grid.Row="9"  Grid.Column="1"  Command="{Binding ReceiptViewCommand}"   Background="Transparent" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button" >
                            <Grid>
                                <Border Background="#FFFFFF" BorderThickness="1" CornerRadius="6" BorderBrush="#1BA1C8" />
                                <Grid >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="13*"></RowDefinition>
                                        <RowDefinition Height="25*"></RowDefinition>
                                        <RowDefinition Height="12*"></RowDefinition>
                                    </Grid.RowDefinitions>

                                    <Viewbox Grid.Row="1" HorizontalAlignment="Center">
                                        <controls:LetterSpacingTextBlock Text="영수증보기" Style="{StaticResource ButtonTextStyle}" />
                                    </Viewbox>
                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Row="9"  Grid.Column="3"  Command="{Binding InitializeChargerCommand}"  Style="{StaticResource CommonConfirmButtonStyle}"/>
               
            </Grid>
    
        </Border>
    </Grid>
</UserControl>
