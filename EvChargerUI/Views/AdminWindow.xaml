<Window x:Class="EvChargerUI.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EvChargerUI.Views"
        xmlns:controls="clr-namespace:EvChargerUI.Commons.Controls"
        mc:Ignorable="d"
        Width="768" Height="574" ResizeMode="NoResize"
        WindowStyle="None">
    <Grid Background="#F3F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="440"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="728"/>
            <ColumnDefinition Width="20"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="1" Grid.Column="1" MouseLeftButtonDown="TitleBarGrid_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="124"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="66"/>
            </Grid.ColumnDefinitions>
            <controls:LetterSpacingTextBlock Grid.Column="0" Text="환경공단 충전기 제어 프로그램 홈" Style="{StaticResource AdminTitleStyle}"/>
            <Border Grid.Column="2" BorderBrush="#1BA1C8" BorderThickness="1" Padding="8,0" Height="22" CornerRadius="11" Background="#FFFFFF">
                <controls:LetterSpacingTextBlock Text="{Binding AppVersion, StringFormat='ver {0}'}" Style="{StaticResource AdminTitleVersionStyle}"/>
            </Border>

            <Button Grid.Column="5" Background="Transparent" BorderThickness="0" Command="{Binding ShowKeyboardCommand}" >
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#FFFFFF" BorderBrush="#DEE2E7" BorderThickness="1" CornerRadius="4">
                            <controls:LetterSpacingTextBlock FontFamily="{StaticResource PretendardFont}" FontSize="13" LineHeight="20" Foreground="#475263" LetterSpacing="-0.2" Text="{Binding ShowKeyboardCaption}" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="7" Background="Transparent" BorderThickness="0" Command="{Binding ExitCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#E9EBEF" CornerRadius="4">
                            <controls:LetterSpacingTextBlock FontFamily="{StaticResource PretendardFont}" FontSize="13" LineHeight="20" Foreground="#475263" LetterSpacing="-0.2" Text="나가기" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
        <Line Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Stroke="#DEE2E7" StrokeThickness="1" X1="0" Y1="0" X2="296" Y2="0" Stretch="Fill"/>
        <Grid Grid.Row="3" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="12"/>
                
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="46"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="12"/>

                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="12"/>

                <ColumnDefinition Width="58"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="/Images/ic_electric_bolt.png" VerticalAlignment="Center"/>
            <controls:LetterSpacingTextBlock Grid.Column="2" Text="충전소명" Style="{StaticResource AdminChargerInfoTitleStyle}"/>
            <controls:LetterSpacingTextBlock Grid.Column="4" Text="{Binding StationName}" Style="{StaticResource AdminChargerInfoContentBoldStyle}"/>
            <Image Grid.Column="6" Source="/Images/ic_check_circle.png" VerticalAlignment="Center"/>
            <controls:LetterSpacingTextBlock Grid.Column="8" Text="충전소ID" Style="{StaticResource AdminChargerInfoTitleStyle}"/>
            <controls:LetterSpacingTextBlock Grid.Column="10" Text="{Binding StationId}" Style="{StaticResource AdminChargerInfoContentBoldStyle}"/>
            <Image Grid.Column="12" Source="/Images/ic_schedule.png" VerticalAlignment="Center"/>
            <controls:LetterSpacingTextBlock Grid.Column="14" Text="현재시간" Style="{StaticResource AdminChargerInfoTitleStyle}"/>
            <controls:LetterSpacingTextBlock Grid.Column="16" Text="{Binding CurrentTime}" Style="{StaticResource AdminChargerInfoContentStyle}"/>
            <controls:LetterSpacingTextBlock Grid.Column="18" Text="UI업데이트" Style="{StaticResource AdminChargerInfoTitleStyle}"/>
            <controls:LetterSpacingTextBlock Grid.Column="20" Text="{Binding UiUpdateDate}" Style="{StaticResource AdminChargerInfoContentStyle}"/>
        </Grid>
        <ContentControl Grid.Row="5" Grid.Column="1" HorizontalAlignment="Center" Height="440" Width="728" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
